generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlite"
}

model ImagemProcessada {
    id Int @id @default(autoincrement())
    imagem String
    status String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    marcaImagems MarcaImagem[]
}

model MarcaImagem{
    id Int @id @default(autoincrement())
    nome String

    imagemProcessadaId Int

    imagemProcessada ImagemProcessada @relation(fields: [imagemProcessadaId], references: [id], onDelete: Cascade)
}
